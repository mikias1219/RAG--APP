# Site snippet for Ubuntu + Nginx in front of Gunicorn.
# Copy to /etc/nginx/sites-available/rag-portal and symlink to sites-enabled.

server {
    listen 80;
    server_name _;   # replace with your VM DNS name or public IP
    client_max_body_size 25m;
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options DENY;
    add_header Referrer-Policy strict-origin-when-cross-origin;

    location /static/ {
        alias /var/www/rag-portal/staticfiles/;
        expires 7d;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
    }
}

# After TLS with Let's Encrypt, use certbot and listen 443 ssl.
